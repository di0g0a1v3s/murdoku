        {
          "kind": "person-direction",
          "personA": "dutch-schultz-jr-",
          "direction": "NE",
          "personB": "magnolia-bloom",
          "text": "A poker chip, bearing the El Paraiso logo, was discovered just to the north-east of where Magnolia had last been seen."
