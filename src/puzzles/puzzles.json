      "clues": [
        {
          "kind": "person-in-room",
          "person": "marco-bellini",
          "roomId": "the-secret-library",
          "text": "A faint scent of aged parchment clung to Marco Bellini, confirming his presence in the shadowed depths of the library."
        },
        {
          "kind": "person-in-room",
          "person": "isabella-rossi",
          "roomId": "the-gilded-gallery",
          "text": "Glimmering gold dust, perhaps from the gallery's elaborate frames, sparkled on Isabella Rossi's dark gown."
        },
        {
          "kind": "person-in-room",
          "person": "giovanni-moretti",
          "roomId": "the-grand-ballroom",
          "text": "The echo of a lone waltz still lingered in the grand ballroom, where Giovanni Moretti was last seen."
        },
        {
          "kind": "person-in-room",
          "person": "dottore-lombardi",
          "roomId": "the-observatory",
          "text": "The celestial charts in the Observatory suggest Dottore Lombardi was consumed by cosmic matters when tragedy struck."
        },
        {
          "kind": "person-beside-object",
          "person": "dottore-lombardi",
          "objectKind": "desk",
          "text": "Scrawled notes and star maps lay scattered beside a mahogany desk, evidence of the Dottore's studies."
        },
        {
          "kind": "persons-same-room",
          "personA": "marco-bellini",
          "personB": "contessa-valeriana",
          "text": "A shared affinity for forbidden knowledge drew Marco Bellini and Contessa Valeriana together amidst the library's secrets."
        },
        {
          "kind": "persons-same-room",
          "personA": "isabella-rossi",
          "personB": "signor-esposito",
          "text": "The gilded gallery bore witness to Isabella Rossi's and Signor Esposito's shared appreciation for the finer things in life."
        },
        {
          "kind": "persons-not-same-room",
          "personA": "giovanni-moretti",
          "personB": "dottore-lombardi",
          "text": "Whispers alluded to a strained relationship between Giovanni Moretti and Dottore Lombardi, keeping them far apart."
        },
        {
          "kind": "room-population",
          "roomId": "the-grand-ballroom",
          "count": 1,
          "text": "Only one soul dared to brave the vastness of the Grand Ballroom, lost amidst the opulent decay."
        },
        {
          "kind": "room-population",
          "roomId": "the-observatory",
          "count": 1,
          "text": "The Observatory's solitude provided the perfect cover for the murderer."
        },
        {
          "kind": "person-on-object",
          "person": "marco-bellini",
          "objectKind": "desk",
          "text": "Dust motes danced in the candlelight illuminating the desk where Bellini lingered, seemingly engrossed in papers rather than the festivities beyond the library's heavy door."
        },
        {
          "kind": "person-direction",
          "personA": "contessa-valeriana",
          "direction": "SE",
          "personB": "signor-esposito",
          "text": "Through the swirling fog of the grand hall, I spied the Contessa's peacock mask, always a few steps southeast of where Signor Esposito lingered near the shadowed archway."
        }
      ],
