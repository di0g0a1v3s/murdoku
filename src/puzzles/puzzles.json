        {
          "kind": "person-on-object",
          "person": "candy-cane",
          "objectKind": "bed",
          "text": "The pool boy confirmed that Candy was lounging on one of the beds."
        },
        {
          "kind": "person-beside-object",
          "person": "rex-riviera",
          "objectKind": "sofa",
          "text": "I found Rex's towel discarded on a sofa."
        },
        {
          "kind": "person-on-object",
          "person": "silas-blackwood",
          "objectKind": "desk",
          "text": "Silas always insisted on having a desk in the smoke-filled lounge so he could work on his book."
        },
        {
          "kind": "person-beside-object",
          "person": "magnolia-bloom",
          "objectKind": "bed",
          "text": "Bloom looked pale as the linen in that poolside cabana, a discarded hand near the rumpled sheets."
        },
        {
          "kind": "person-direction",
          "personA": "rex-riviera",
          "direction": "SW",
          "personB": "dutch-schultz-jr-",
          "text": "Riviera, I recall, kept mostly to the southwestern corner of the veranda, always watching young Schultz."
